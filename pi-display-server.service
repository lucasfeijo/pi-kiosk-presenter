[Unit]
Description=Pi Display Server — remote HDMI layout control
After=multi-user.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=pi
Environment=XAUTHORITY=/home/pi/.Xauthority
Environment=DISPLAY_PORT=8686
# Set to 0 to disable HTTPS and use plain HTTP instead:
Environment=SSL_SELFSIGNED=1
ExecStart=/bin/bash -lc 'for i in $(seq 1 30); do for d in :0 :1 :2; do if DISPLAY="$d" XAUTHORITY="/home/pi/.Xauthority" xdpyinfo >/dev/null 2>&1; then export DISPLAY="$d"; exec /usr/bin/python3 /opt/pi-display-server/display_server.py; fi; done; sleep 2; done; echo "No X display available" >&2; exit 1'
Restart=on-failure
RestartSec=1
TimeoutStopSec=3
KillMode=mixed
KillSignal=SIGTERM
# Allow nice -n -10 and ionice real-time for mpv
AmbientCapabilities=CAP_SYS_NICE
LimitRTPRIO=50

[Install]
WantedBy=multi-user.target
