[Unit]
Description=Pi Display Server — remote HDMI layout control
After=graphical.target
Wants=graphical.target

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
Environment=DISPLAY_PORT=8686
ExecStart=/usr/bin/python3 /opt/pi-display-server/display_server.py
Restart=on-failure
RestartSec=1
TimeoutStopSec=3
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=graphical.target
